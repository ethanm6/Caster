<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Caster" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <!-- Keep system-bar insets applied by the framework (Android 15 forces
             edge-to-edge otherwise, putting the toolbar under the status bar). -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">?attr/isLightTheme</item>
        <!-- Soften the M3 Expressive press-morph springs; defaults feel too fast. -->
        <item name="motionSpringFastSpatial">@style/Spring.Caster.Spatial</item>
        <item name="motionSpringFastEffects">@style/Spring.Caster.Effects</item>
    </style>

    <!-- Stock fast springs are spatial 800/0.6, effects 3800/1 — these are ~slow tier. -->
    <style name="Spring.Caster.Spatial" parent="">
        <item name="stiffness">250</item>
        <item name="damping">0.8</item>
    </style>

    <style name="Spring.Caster.Effects" parent="">
        <item name="stiffness">900</item>
        <item name="damping">1</item>
    </style>
</resources>
